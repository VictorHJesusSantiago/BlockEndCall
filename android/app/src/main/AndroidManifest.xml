<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".BlockEndCallApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BlockEndCall"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BlockEndCall.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.LoginActivity" android:exported="false" />
        <activity android:name=".ui.RegisterActivity" android:exported="false" />
        <activity android:name=".ui.MainActivity" android:exported="false" />
        <activity android:name=".ui.BlockedListActivity" android:exported="false" />
        <activity android:name=".ui.ReportNumberActivity" android:exported="false" />
        <activity android:name=".ui.NumberDetailActivity" android:exported="false" />
        <activity android:name=".ui.CheckNumberActivity" android:exported="false" />
        <activity android:name=".ui.StatsActivity" android:exported="false" />
        <activity android:name=".ui.MyReportsActivity" android:exported="false" />
        <activity android:name=".ui.BlockedCallLogActivity" android:exported="false" />
        <activity android:name=".ui.ProfileActivity" android:exported="false" />
        <activity android:name=".ui.SettingsActivity" android:exported="false" />
        <activity android:name=".ui.CallLogActivity" android:exported="false" />

        <receiver android:name=".receiver.ScheduledBlockingReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.blockendcall.ACTION_ENABLE_BLOCK"/>
                <action android:name="com.blockendcall.ACTION_DISABLE_BLOCK"/>
            </intent-filter>
        </receiver>

        <!-- CallScreeningService: intercepts incoming calls and checks against backend -->
        <service
            android:name=".service.BlockCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

    </application>
</manifest>
