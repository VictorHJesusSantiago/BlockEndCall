<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Gradient hero -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_wave"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_welcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BlockEndCall · Proteção Comunitária"
                    android:textSize="12sp"
                    android:textColor="#AAFFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_shield_status"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_shield_off" />
        </LinearLayout>

        <!-- Screening card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#22FFFFFF"
            app:cardElevation="0dp"
            app:strokeColor="#44FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Triagem de Chamadas"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/tv_screening_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Não configurado"
                        android:textSize="11sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enable_screening"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Ativar"
                    android:textSize="11sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/white"
                    android:textColor="@color/white"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Quick actions 2x2 grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_check"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/cat_scam_bg"
                    app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verificar"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/cat_scam"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_stats"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/cat_robocall_bg"
                    app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estatísticas"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/cat_robocall"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_blocked_log"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/cat_telemarketing_bg"
                    app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Histórico"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/cat_telemarketing"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_my_reports"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/cat_debt_bg"
                    app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Meus Reportes"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/cat_debt"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Main action buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_blocked"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚫  Ver Números Bloqueados"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_report_number"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📢  Reportar Número Spam"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sair"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
