<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar_gradient"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="Estatísticas"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:visibility="gone" />

                <!-- Hero row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <!-- Confirmed -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/cat_scam_bg"
                        app:cardElevation="3dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚫" android:textSize="28sp" />
                            <TextView android:id="@+id/tv_total_confirmed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_scam" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Confirmados"
                                android:textSize="11sp"
                                android:textColor="@color/cat_scam"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pending -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/cat_telemarketing_bg"
                        app:cardElevation="3dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⏳" android:textSize="28sp" />
                            <TextView android:id="@+id/tv_total_pending"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_telemarketing" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Em Análise"
                                android:textSize="11sp"
                                android:textColor="@color/cat_telemarketing"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Reports + Users row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/cat_robocall_bg"
                        app:cardElevation="3dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📢" android:textSize="28sp" />
                            <TextView android:id="@+id/tv_total_reports"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_robocall" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reportes Totais"
                                android:textSize="11sp"
                                android:textColor="@color/cat_robocall"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/cat_debt_bg"
                        app:cardElevation="3dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👥" android:textSize="28sp" />
                            <TextView android:id="@+id/tv_total_users"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_debt" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usuários Ativos"
                                android:textSize="11sp"
                                android:textColor="@color/cat_debt"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Category breakdown -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Por Categoria"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_telemarketing_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📞" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_telemarketing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_telemarketing" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telemarketing"
                                android:textSize="10sp"
                                android:textColor="@color/cat_telemarketing"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_scam_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💀" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_scam"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_scam" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scam"
                                android:textSize="10sp"
                                android:textColor="@color/cat_scam"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_robocall_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🤖" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_robocall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_robocall" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Robocall"
                                android:textSize="10sp"
                                android:textColor="@color/cat_robocall"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_debt_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💳" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_debt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_debt" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cobrança"
                                android:textSize="10sp"
                                android:textColor="@color/cat_debt"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_phishing_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎣" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_phishing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_phishing" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phishing"
                                android:textSize="10sp"
                                android:textColor="@color/cat_phishing"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/cat_unknown_bg"
                        app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❓" android:textSize="20sp" />
                            <TextView android:id="@+id/tv_count_unknown"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/cat_unknown" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outros"
                                android:textSize="10sp"
                                android:textColor="@color/cat_unknown"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Trending section -->
                <LinearLayout
                    android:id="@+id/layout_trending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Em Alta esta Semana"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:paddingHorizontal="20dp"
                        android:paddingBottom="10dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_trending"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
